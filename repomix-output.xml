}

@layer base {
  * {
    @apply border-border outline-ring/50;
  }

  body {
    @apply bg-background text-foreground;
    min-height: 100vh;
    background-image:
      radial-gradient(circle at top left, color-mix(in oklch, var(--primary) 12%, transparent), transparent 28%),
      radial-gradient(circle at bottom right, color-mix(in oklch, var(--brand-emerald) 10%, transparent), transparent 30%);
    background-attachment: fixed;
  }

  html {
    @apply font-sans;
  }

  ::selection {
    background-color: color-mix(in oklch, var(--primary) 28%, white 72%);
    color: var(--foreground);
  }
}

@layer utilities {
  .brand-gradient {
    background-image: linear-gradient(
      120deg,
      var(--primary) 0%,
      var(--brand-blue) 100%
    );
  }
  .text-gradient {
    background-image: linear-gradient(
      120deg,
      var(--primary) 0%,
      var(--brand-blue) 55%,
      var(--brand-emerald) 110%
    );
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .glass {
    background-color: color-mix(in oklch, var(--card) 70%, transparent);
    backdrop-filter: blur(16px);
